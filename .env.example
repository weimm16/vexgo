# JWT密钥（生产环境必须设置为长随机字符串）
JWT_SECRET=your-very-long-random-secret-here

# 数据库配置（可选，默认使用SQLite）
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=vexgo_user
# DB_PASSWORD=your-db-password
# DB_NAME=vexgo_db

# 或者使用PostgreSQL：
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=vexgo_user
# DB_PASSWORD=your-db-password
# DB_NAME=vexgo_db
# DB_SSL_MODE=disable

# 服务器配置（可选）
# ADDR=0.0.0.0
# PORT=3001
# DATA_DIR=/app/data
